# ─── DATABASE ────────────────────────────────────────────
# Local development (leave TURSO vars empty to use this)
DATABASE_URL="file:./dev.db"
# Production (Turso) — set these to use remote database
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# ─── STEAM ───────────────────────────────────────────────
STEAM_API_KEY=""
ALLOWED_STEAM_ID=""

# ─── MARKET DATA PROVIDERS ───────────────────────────────
PRICEMPIRE_API_KEY=""
CSFLOAT_API_KEY=""

# ─── AI: Google OAuth (Gemini) ───────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── AI: API Keys ───────────────────────────────────────
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# ─── SECURITY ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
TOKEN_ENCRYPTION_KEY=""

# ─── VERCEL CRON ─────────────────────────────────────────
# Vercel auto-sets this when you configure cron jobs
CRON_SECRET=""
