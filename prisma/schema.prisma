generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String          @id @default(cuid())
  steamId        String          @unique
  displayName    String
  avatarUrl      String?
  createdAt      DateTime        @default(now())
  lastLogin      DateTime        @default(now())
  chatSessions   ChatSession[]
  chatMessages   ChatMessage[]
  inventoryItems InventoryItem[]
}

model Item {
  id             String          @id @default(cuid())
  marketHashName String          @unique
  name           String
  weapon         String?
  skin           String?
  category       String
  rarity         String?
  exterior       String?
  imageUrl       String?
  isWatched      Boolean         @default(false)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  type           String?
  notes          String?
  candlesticks   Candlestick[]
  groups         ItemGroup[]
  inventoryItems InventoryItem[]
  priceSnapshots PriceSnapshot[]
}

model PriceSnapshot {
  id        Int      @id @default(autoincrement())
  itemId    String
  price     Float
  volume    Int?
  source    String   @default("pricempire")
  timestamp DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, timestamp])
}

model Candlestick {
  id        Int      @id @default(autoincrement())
  itemId    String
  interval  String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Int      @default(0)
  timestamp DateTime
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, interval, timestamp])
  @@index([itemId, interval, timestamp])
}

model InventoryItem {
  id            String    @id @default(cuid())
  userId        String
  itemId        String
  assetId       String    @unique
  floatValue    Float?
  paintSeed     Int?
  stickers      String?
  acquiredAt    DateTime  @default(now())
  acquiredPrice Float?
  soldAt        DateTime?
  soldPrice     Float?
  item          Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String       @id @default(cuid())
  userId    String
  sessionId String?
  role      String
  content   String
  metadata  String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  type      String
  status    String
  itemCount Int      @default(0)
  duration  Int?
  error     String?
  timestamp DateTime @default(now())
}

model MarketCapSnapshot {
  id             String   @id @default(cuid())
  totalMarketCap Float
  totalListings  Int?
  provider       String   @default("youpin")
  topItems       String?
  timestamp      DateTime @default(now())

  @@index([provider, timestamp])
}

model AppSettings {
  id                      String    @id @default("singleton")
  activeMarketSource      String    @default("csfloat")
  csgotraderSubProvider   String    @default("csfloat")
  activeAIProvider        String    @default("gemini-pro")
  openAiApiKey            String?
  geminiApiKey            String?
  csfloatApiKey           String?
  priceRefreshIntervalMin Int       @default(15)
  watchlistOnly           Boolean   @default(true)
  googleAccessToken       String?
  googleRefreshToken      String?
  googleTokenExpiry       DateTime?
  // DB-based sync lock to prevent concurrent CSFloat access across serverless instances
  syncInProgress          Boolean   @default(false)
  syncStartedAt           DateTime?
}

/// Persists the csgotrader.app bulk price JSON so cold starts don't re-fetch.
/// Singleton row (id="singleton"). The `data` column holds the full JSON blob.
model BulkPriceCache {
  id        String   @id @default("singleton")
  data      String   // JSON blob of the full csgotrader.app/csfloat.json response
  updatedAt DateTime @default(now())
}

model TopMoversCache {
  id        String   @id @default("singleton")
  gainers   String   // JSON array of top 5 gainers
  losers    String   // JSON array of top 5 losers
  source    String   @default("csfloat")
  updatedAt DateTime @default(now())
}

/// Stores the last-request timestamp (ms since epoch) per API queue.
/// Used by the global rate limiter so concurrent serverless isolates
/// respect the same per-provider request cadence.
model RateLimitState {
  queueName     String @id
  lastRequestMs Float  @default(0)
}

model WatchlistGroup {
  id        String      @id @default(cuid())
  name      String
  color     String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  items     ItemGroup[]
}

model ItemGroup {
  id      String         @id @default(cuid())
  itemId  String
  groupId String
  item    Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  group   WatchlistGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([itemId, groupId])
  @@index([itemId])
  @@index([groupId])
}
